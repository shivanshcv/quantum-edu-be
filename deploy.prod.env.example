# Production deploy secrets — copy to deploy.prod.env and fill in.
# Never commit deploy.prod.env (gitignored).
#
#   cp deploy.prod.env.example deploy.prod.env
#
# Deploy from repo root:
#   ./deploy.prod.sh
#
# Prerequisites: AWS CLI (aws configure), Docker running, SSH key readable.

# EC2 (production app server — same host as Django admin if you use one-box layout)
EC2_HOST=your-prod-ec2.elastic-ip-or-dns
EC2_USER=ubuntu
SSH_KEY=~/path/to/your-prod-key.pem

# AWS ECR (create repo quantum-edu-be-production in same region)
AWS_REGION=ap-south-1
ECR_URI=YOUR_ACCOUNT_ID.dkr.ecr.ap-south-1.amazonaws.com/quantum-edu-be-production

# RDS MySQL (production)
RDS_ENDPOINT=your-prod-mysql.xxxxx.ap-south-1.rds.amazonaws.com
RDS_DB=quantum_education
RDS_USER=admin
RDS_PASS=your-strong-prod-password

# JWT — generate: openssl rand -base64 32
JWT_SECRET=your-production-jwt-secret

# Frontend (Amplify custom domain and/or default amplifyapp.com URL), comma-separated
APP_CORS_ORIGINS=https://www.yourdomain.com,https://yourdomain.com
VERIFICATION_BASE_URL=https://www.yourdomain.com/verify-email

# Email
APP_EMAIL_ENABLED=true
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com

# Razorpay — use LIVE keys for real payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Spring profile (override only if needed)
# SPRING_PROFILES_ACTIVE=prod
