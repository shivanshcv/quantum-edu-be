# Copy this file to deploy.env and fill in your values.
# deploy.env is gitignored - never commit it.
#
#   cp deploy.env.example deploy.env
#   # Edit deploy.env with your actual values

# EC2 connection
EC2_HOST=52.66.209.243
EC2_USER=ubuntu
SSH_KEY=~/Downloads/cli-admin.pem

# AWS ECR
AWS_REGION=ap-south-1
ECR_URI=632127306445.dkr.ecr.ap-south-1.amazonaws.com/quantum-edu-be-staging

# RDS
RDS_ENDPOINT=your-db.xxxxx.ap-south-1.rds.amazonaws.com
RDS_DB=quantum_education
RDS_USER=admin
RDS_PASS=your-rds-password

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret

# Frontend URL (for CORS and email verification)
# Netlify: https://quantum-education.netlify.app
# Or custom domain: https://yourdomain.com
APP_CORS_ORIGINS=https://quantum-education.netlify.app
VERIFICATION_BASE_URL=https://quantum-education.netlify.app/verify-email

# Razorpay (optional - defaults in staging)
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
# RAZORPAY_WEBHOOK_SECRET=xxx
